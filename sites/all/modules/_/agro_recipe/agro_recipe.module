/**
 * форма ввода списка сорняков
 */
function agro_recipe_fungi_form($form, &$form_state) {
    // получаем список всех подкатегорий в Болезнях
    $list = array();
    $tids = taxonomy_get_children(71339);
    foreach($tids as $tid) {
        $list[] = $tid->tid;
    }

    // список всех Болезней всех подкатегорий
    // todo получать список только для заданной культуры
    $query = db_select('node', 'n');
    $query->innerJoin('field_data_field_category', 'fc', 'n.nid = fc.entity_id');
    $query->condition('fc.bundle', 'harmful_objects');
    $query->condition('fc.field_category_tid', $list, 'IN');
    $query->condition('n.type', 'harmful_objects');
    $query->fields('n', array('nid', 'title'));
    $hobjects = $query->execute()->fetchAll();

    $options = array();
    foreach($hobjects as $hobject) {
        $options[$hobject->nid] = $hobject->title;
    }

    $form['fungis'] = array(
        '#type' => 'fieldset',
        '#title' => 'Введите одно или несколько значений',
    );
    $form['fungis']['hobjects'] = array(
        '#type' => 'select',
        '#options' => $options,
        '#multiple' => true,
        '#chosen' => true,
        '#default_value' => !empty($_COOKIE['selected_fungis']) ? explode(',', $_COOKIE['selected_fungis']) : array(),
    );

    $form['fungis-submit'] = array(
        '#type' => 'submit',
        '#value' => 'Отправить',
    );
    return $form;
}
