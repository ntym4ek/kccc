/**
 * получить название Вредного объекта по nid
 *
 * @param $hobject_nids - массив nid Вредных объектов
 * @return array - массив array('nid' => 'name')
 */
function _get_hobject_name($hobject_nids) {
    $result = array();
    foreach ($hobject_nids as $nid) {
        $query = db_select('node', 'n');
        $query->condition('n.nid', $nid);
        $query->condition('n.type', 'harmful_objects');
        $query->fields('n', array('title'));
        $result[$nid] = $query->execute()->fetchField();
    }
    return $result;
}

/**
 * получить название термина по tid
 * @param $tids
 * @param bool $lower - приводить к нижнему регистру
 * @return array - массив array('tid' => 'name')
 */
function _get_term_name($tids, $lower = false) {
    $result = array();
    foreach ($tids as $tid) {
        $query = db_select('taxonomy_term_data', 't');
        $query->condition('t.tid', $tid);
        $query->fields('t', array('name'));
        $class = $query->execute()->fetchField();

        $result[$tid] = $lower ? drupal_strtolower($class) : $class;
    }
    return $result;
}

// главная страница
function protection_program_main_page($culture_id) {
    $pp = get_protection_program($culture_id);
    $table = theme('protection_program_table', array('pp' => $pp));

    return $table;
};