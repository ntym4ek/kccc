    // получаем список регионов
    $regions_by_tid = $regions_by_iso = [];
    if ($regions_terms = taxonomy_get_tree(taxonomy_vocabulary_machine_name_load('regions')->vid, 0 , null, true)) {
        foreach ($regions_terms as $region) {
            $iso = empty($region->field_iso_3166_2_ru['und'][0]) ? '' : $region->field_iso_3166_2_ru['und'][0]['value'];
            $regions_by_tid[$region->tid] = ['name' => $region->name, 'iso' => $iso];
            if ($iso) {
                $regions_by_iso[$iso] = ['name' => $region->name, 'tid' => $region->tid];
            }
        }
    }

    foreach ($sales as $key_d => &$dep) {
        foreach ($dep as $key_r => &$rep) {
            if ($GLOBALS['language']->language != 'ru') {

                if (isset($rep['surname'])) $rep['surname'] = translit($rep['surname']);
                if (isset($rep['name']))    $rep['name'] = translit($rep['name']);
                if (isset($rep['name2']))   $rep['name2'] = translit($rep['name2']);
                if (isset($rep['name2']))   $rep['name2'] = translit($rep['name2']);
                if (isset($rep['phones'])) {
                    foreach($rep['phones'] as $key => $phone) {
                        $rep['phones'][$key] = str_replace('доб.', 'add', $phone);
                    }
                }
            }

            // заполнить инфо о регионе
            if (!empty($rep['regions'])) {
                foreach($rep['regions'] as $region_tid => &$region_arr) {
                    $region_arr = empty($regions_by_tid[$region_tid]) ? [] : $regions_by_tid[$region_tid];
                    if ($key_d == 'reps') {
                        $regions_by_iso[$regions_by_tid[$region_tid]['iso']]['reps'] = empty($regions_by_iso[$regions_by_tid[$region_tid]['iso']]['reps']) ? 1 : $regions_by_iso[$regions_by_tid[$region_tid]['iso']]['reps']+1;
                    }
                }
            }
        }
    }

    $sales['regions_by_tid'] = $regions_by_tid;
    $sales['regions_by_iso'] = $regions_by_iso;


    return $sales;
}


/**
 * callback function
 * источник данных о представителях (исп. в приложении)
 */
function _representatives_source($region_id = null)
{
    drupal_json_output(['representatives' => _get_representative($region_id)]);
    drupal_exit();
}

/**
 * используется в корзине
 * @return array|mixed
 */
function _get_representative($tid)
{
    $sales = representatives_get_representatives_list();
    if ($tid) {
        $representatives = [];
        foreach ($sales['reps'] as $rep) {
            if (isset($rep['regions'][$tid]) && !empty($rep['access'])) {
                $representatives['reps'][$tid] = $rep;
            }
        }
        if (empty($representatives)) {
            foreach ($sales['heads'] as $head) {
                if (isset($head['regions'][$tid]) && !empty($head['access'])) {
                    $representatives['heads'][$tid] = $head;
                }
            }
        }
        return $representatives;
    }
    return $sales;
}

/**
 * callback function
 * источник данных об экспертах (исп. в приложении)
 */
function _experts_source($region_id = null)
{
    drupal_json_output(['representatives' => _get_experts($region_id)]);
    drupal_exit();
}

function _get_experts($tid)
{
    $reps = representatives_get_representatives_list();

    $representatives = [];
    foreach ($reps as $region => $reg) {
        foreach ($reg as $rep) {
            if (!empty($rep['expert'])) {
                if (empty($tid) || isset($rep['regions'][$tid])) {
                    unset($rep['regions']);
                    $rep['office'] = 'Научный консультант';
                    $representatives['expert'][] = $rep;
                }
            }
        }
    }
    if (empty($representatives)) {
        $representatives['expert'][] = $reps['tambov'][0];
    }
    return $representatives;

}
