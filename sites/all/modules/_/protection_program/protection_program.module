/**
 * @param $prep - препарат, для которого получить регламенты
 * @param $culture - nid культуры
 * @param $function - tid, функция, выполняемая препаратом (он же категория)
 * @param $hobjects - массив массивов 'entity_id' => array('type' => 'weed, fungi, pest', 'class' => 'entity, life_time, bot_class', 'cured' => 0)
 *
 * @return array
 * вернуть массив регламентов, отфильтрованый по заданным культурам, функции и вредным объектам
 * массив вредных объектов дополнительно проверить на вхождение в регламенты
 */
function check_reglament($data, &$hobjects) {

    $regl_wrapper = entity_metadata_wrapper('field_collection_item', $data['rid']);
    $result = false;

    // если ВО не заданы - регламент соответствует
    if (empty($hobjects)) return true;

    // если десикация - подходит, отсев и запрос будут дальше (обрабатывается и запрашивается как фича)
    if ($regl_wrapper->field_pd_r_function->tid->value() == AGRO_CATEGORY_DESSICANTS_TID) return true;


    // проверить ВО - ВО
    if ($regl_wrapper->field_pd_r_hobjects->count()) {
        foreach ($regl_wrapper->field_pd_r_hobjects as $r_item) {
            // ищем id ВО в принятом массиве ВО
            if ($r_item->value()) {
                $ho_id = $r_item->nid->value();
                if (isset($hobjects[$ho_id])) {
                    if (!$data['by_option'] || $data['poll_option'])
                        $hobjects[$ho_id]['preparations'][$data['pid']] = array(
                            'pid' => $data['pid'],
                            'mandatory' => $data['mandatory'],
                            'option_own' => $data['by_option'],
                            'rating' => 0,
                        );
                    $result = true;
                }
            }
        }
    }

    $group_hobjects = array();

    // список ВО за вычетом исключений для SQL запроса только по ним
    $arr_nids = $ho_hobjects = array();
    foreach($hobjects as $key => $hobject)
        if (empty($data['exceptions_ho'][$key])) $arr_nids[] = $key;

    // список групп исключений
    $arr_exept_gr = array();
    if (!empty($data['exceptions_gr'])) {
        foreach ($data['exceptions_gr'] as $item_e) {
            $parents = taxonomy_get_parents_all($item_e);
            $level = count($parents);
            $arr_exept_gr[$level][] = $item_e;
        }
    }

    // для Сорняков проверяем вхождение списка ВО в заданные в регламенте группы
    if ($regl_wrapper->field_pd_r_function->tid->value() == AGRO_CATEGORY_HERBICIDES_TID) {
        if ($regl_wrapper->field_pd_r_hobjects_groups->count()) {
            foreach ($regl_wrapper->field_pd_r_hobjects_groups as $rg_item) {
                $group_wrapper = entity_metadata_wrapper('field_collection_item', $rg_item->value());

                // массивы значений Продолжительности жизни и Групп
                $arr_lt = array();
                if ($group_wrapper->field_pd_r_hg_life_time->count()) {
                    foreach ($group_wrapper->field_pd_r_hg_life_time as $lt_item) {
                        $arr_lt[$lt_item->tid->value()] = $lt_item->tid->value();
                    }
                }

                foreach ($group_wrapper->field_pd_r_hg_group as $g_item) {

                    $tid_bc = $g_item->tid->value();
                    $parents = taxonomy_get_parents_all($tid_bc);
                    $level = count($parents);

                    // получить список ВО входящщих в группы вместе с подгруппами
                    $query = db_select('node', 'n');
                    $query->condition('n.type', 'harmful_objects');
                    $query->join('field_data_field_weed_life_time', 'lt', 'lt.entity_id = n.nid');
                    if ($level == 1 || !empty($arr_exept_gr[1])) $query->join('field_data_field_weed_group', 'g', 'g.entity_id = n.nid');
                    if ($level == 2 || !empty($arr_exept_gr[2])) $query->join('field_data_field_weed_class', 'c', 'c.entity_id = n.nid');
                    if ($level == 3 || !empty($arr_exept_gr[3])) $query->join('field_data_field_weed_order', 'o', 'o.entity_id = n.nid');
                    if ($level == 4 || !empty($arr_exept_gr[4])) $query->join('field_data_field_weed_family', 'f', 'f.entity_id = n.nid');
                    if ($level == 5 || !empty($arr_exept_gr[5])) $query->join('field_data_field_weed_kind', 'k', 'k.entity_id = n.nid');
                    $query->condition('n.nid', $arr_nids, 'IN');
                    if ($arr_lt) $query->condition('lt.field_weed_life_time_tid', $arr_lt, 'IN');
                    if ($level == 1) $query->condition('g.field_weed_group_tid', $tid_bc);
                    if ($level == 2) $query->condition('c.field_weed_class_tid', $tid_bc);
                    if ($level == 3) $query->condition('o.field_weed_order_tid', $tid_bc);
                    if ($level == 4) $query->condition('f.field_weed_family_tid', $tid_bc);
                    if ($level == 5) $query->condition('k.field_weed_kind_tid', $tid_bc);
                    // группы исключения
                    if (!empty($arr_exept_gr[1])) $query->condition('g.field_weed_group_tid', $arr_exept_gr[1], 'NOT IN');
                    if (!empty($arr_exept_gr[2])) $query->condition('c.field_weed_class_tid', $arr_exept_gr[2], 'NOT IN');
                    if (!empty($arr_exept_gr[3])) $query->condition('o.field_weed_order_tid', $arr_exept_gr[3], 'NOT IN');
                    if (!empty($arr_exept_gr[4])) $query->condition('f.field_weed_family_tid', $arr_exept_gr[4], 'NOT IN');
                    if (!empty($arr_exept_gr[5])) $query->condition('k.field_weed_kind_tid', $arr_exept_gr[5], 'NOT IN');

                    $query->fields('n', array('nid'));
                    $nids = $query->execute()->fetchAll();

                    if ($nids) {
                        foreach ($nids as $nid) $group_hobjects[$nid->nid] = $nid->nid;
                    }
                }
            }

            // проверка на вхождение заданных ВО в группы ВО из регламента
            foreach($hobjects as $key => $hobject) {
                if (isset($group_hobjects[$key])) {
                    if (!$data['by_option'] || $data['poll_option'])
                        $hobjects[$key]['preparations'][$data['pid']] = array(
                            'pid' => $data['pid'],
                            'mandatory' => $data['mandatory'],
                            'option_own' => $data['by_option'],
                            'rating' => 0,
                        );
                    $result = true;
                }
            }
        }
    }

    return $result;
}

/**
 * @param $periods_list - массив объектов taxonomy_term (поле field_growth_stages_set->field_mc_periods Культуры)
 *
 * @return array
 * отсортированный по весу массив tid и name
 */
function _get_processing_periods($periods_list) {
    $options = array();
    if (!empty($periods_list)) {
        foreach ($periods_list as $p_item) {
            $periods[$p_item->weight] = array(
                'tid' => $p_item->tid,
                'name' => $p_item->name,
            );
        }
        ksort($periods);

        foreach ($periods as $period) $options[$period['tid']] = $period['name'];
    }

    return $options;
}

function taxonomy_get_children_all($tid, $vid = 0){
    $c = taxonomy_get_children($tid, $vid);
    $result = array();
    foreach ($c as $t => $d){
        $result[$t] = $d;
        $below = taxonomy_get_children_all($t, $vid);
        if (!empty($below)) {
            foreach ($below as $nt => $nd){
                $result[$nt] = $nd;
            }
        }
    }
    return $result;
}