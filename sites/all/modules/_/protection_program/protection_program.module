<?php
function protection_program_menu() {
    $items['protection-program/add'] = array(
        'page callback' => 'pp_callback',
        'access callback' => TRUE,
        'type' => MENU_CALLBACK,
    );
    $items['protection-program/%/edit'] = array(
        'page callback' => 'pp_edit_callback',
        'page arguments' => array(1),
        'access callback' => TRUE,
        'type' => MENU_CALLBACK,
    );
    $items['protection-program/%/del'] = array(
        'page callback' => 'pp_del_callback',
        'page arguments' => array(1),
        'access callback' => TRUE,
        'type' => MENU_CALLBACK,
    );
    $items['protection-program/%/description'] = array(
        'page callback' => 'pp_description_callback',
        'page arguments' => array(1),
        'access callback' => TRUE,
        'type' => MENU_CALLBACK,
    );
    // фон
    $items['protection-program/%/bg'] = array(
        'page callback' => 'pp_bg_callback',
        'page arguments' => array(1),
        'access callback' => TRUE,
        'type' => MENU_CALLBACK,
    );
    // этапы
    $items['protection-program/%/stage/add'] = array(
        'page callback' => 'pp_stage_callback',
        'page arguments' => array(1),
        'access callback' => TRUE,
        'type' => MENU_CALLBACK,
    );
    $items['protection-program/%/stage/%/edit'] = array(
        'page callback' => 'pp_stage_edit_callback',
        'page arguments' => array(1,3),
        'access callback' => TRUE,
        'type' => MENU_CALLBACK,
    );
    $items['protection-program/%/stage/%/del'] = array(
        'page callback' => 'pp_stage_del_callback',
        'page arguments' => array(1,3),
        'access callback' => TRUE,
        'type' => MENU_CALLBACK,
    );

    return $items;
}


/**
 * callback функция добавления ПЗ
 */
function pp_callback($mode = NULL) {
    if ($mode == 'ajax') {
        ctools_include('ajax'); ctools_include('modal');
        drupal_add_css(drupal_get_path('module', 'protection_program') . '/css/protection_program.css');

        $form_state = array('ajax' => TRUE, 'title' => 'Программа защиты');
        $output = ctools_modal_form_wrapper('pp_form', $form_state);
        if (!empty($form_state['ajax_commands'])) $output = $form_state['ajax_commands'];
        print ajax_render($output);
        drupal_exit();
    }
    else return drupal_get_form('pp_form');
}
/**
 * callback функция редактирования описания ПЗ
 */
function pp_description_callback($ppid, $mode = NULL) {
    if ($mode == 'ajax') {
        ctools_include('ajax'); ctools_include('modal');

        $form_state = array('ajax' => TRUE, 'title' => 'Программа защиты');
        $form_state['build_info']['args'] = array('ppid' => $ppid);
        $output = ctools_modal_form_wrapper('pp_form', $form_state);
        if (!empty($form_state['ajax_commands'])) $output = $form_state['ajax_commands'];
        print ajax_render($output);
        drupal_exit();
    }
    else return drupal_get_form('pp_form', $ppid);
}
/**
 * форма добавления/редактирования ПЗ
 */
function pp_form($form, &$form_state, $ppid = '') {
    // если ppid задан, заполнить переменные
    $name = $descr = '';
    $cids = array();
    if ($ppid) {
        $node_wrapper = entity_metadata_wrapper('node', $ppid);
        $name = $node_wrapper->title->value();
        $descr = $node_wrapper->body->summary->value();
        foreach ($node_wrapper->field_pp_cultures as $item_c)
            $cids[] = $item_c->nid->value();
    }

    $form = array(
        '#prefix' => '<div id="pp_frm">',
        '#suffix' => '</div>',
        '#attributes' => array('class' => array('custom-form'))
    );

    $form['fs1'] = array('#type' => 'fieldset', '#title' => 'Укажите название и описание');
    $form['fs1']['title'] = array(
        '#type' => 'textfield',
        '#attributes' => array('placeholder' => 'Название'),
        '#required' => true,
        '#default_value' => $name,
    );
    $form['fs1']['description'] = array(
        '#type' => 'textfield',
        '#attributes' => array('placeholder' => 'Краткое описание'),
        '#required' => true,
        '#default_value' => $descr,
    );


    // список всех Культур
    $query = db_select('node', 'n');
    $query->condition('n.type', 'main_cultures');
    $query->fields('n', array('nid', 'title'));
    $result_cs = $query->execute()->fetchAll();

    $options = $cids ? $options = array() : array('Выберите с/х культуру');
    foreach($result_cs as $c_item) {
        $options[$c_item->nid] = $c_item->title;
    }

    $form['fs2'] = array('#type' => 'fieldset', '#title' => 'Выберите одну или несколько культур');
    $form['fs2']['culture'] = array(
        '#type' => 'select',
        '#options' => $options,
        '#chosen' => true,
        '#multiple' => true,
        '#required' => true,
        '#default_value' => $cids,
    );
    if ($ppid)
        $form['ppid'] = array(
            '#type' => 'hidden',
            '#value' => $ppid,
        );

    $form['fs3'] = array('#type' => 'container', '#attributes' => array('class' => array('form-actions')));
    $form['fs3']['pp-submit'] = array(
        '#type' => 'submit',
        '#value' => 'Сохранить',
    );

    return $form;
}
function pp_form_validate($form, &$form_state) {
    if (empty($form_state['values']['culture'])) {
        form_set_error('culture', 'Поле Культура обязательно для заполнения');
    }
}
function pp_form_submit($form, &$form_state) {
    if (empty($form_state['values']['ppid'])) {
        // создать новую ПЗ
        $node = new stdClass();
        $node->type = 'protection_program';
        node_object_prepare($node);
        $node->language = LANGUAGE_NONE;
        $node->body[LANGUAGE_NONE][0]['format'] = 'filtered_html';
    } else {
        $node = node_load($form_state['values']['ppid']);
    }

    $node->field_pp_cultures[LANGUAGE_NONE] = array();
    $node->title = $form_state['values']['title'];
    $node->body[LANGUAGE_NONE][0]['summary'] = $form_state['values']['description'];
    foreach($form_state['values']['culture'] as $item_c)
        $node->field_pp_cultures[LANGUAGE_NONE][]['target_id'] = $item_c;
    node_save($node);

    $url = '/protection-program/' . $node->nid . '/edit';
    if (empty($form_state['values']['ppid'])) $message = 'Программа защиты добавлена.<br />Сейчас вы будете перенаправлены на страницу <a href="' . $url . '">редактирования</a>.';
    else $message = 'Описание программы защиты обновлено.<br />Сейчас вы будете перенаправлены на страницу <a href="' . $url . '">редактирования</a>.';
    $form_state['ajax_commands'][] = ajax_command_html('#modal-content', $message);
    $form_state['ajax_commands'][] = ctools_ajax_command_redirect($url);
    $form_state['ajax_commands'][] = ajax_command_prepend('#modal-content', theme('status_messages'));
}

/**
 * callback функция Страница редактирования ПЗ
 */
function pp_edit_callback($ppid) {

    if ($pp = get_protection_program($ppid)) {
        $output = theme('protection_program_table', array('pp' => $pp));
        $output = '<div class="protection-program full">' .$output . '</div>';
    }
    else $output = 'Страница не найдена';

    return $output;
}

/**
 * callback функция удаления периода роста
 */
function pp_del_callback($ppid, $mode = NULL) {
    if ($mode == 'ajax') {
        ctools_include('ajax'); ctools_include('modal');
        $form_state = array('ajax' => TRUE, 'title' => 'Удалить программу защиты');
        $form_state['build_info']['args'] = array('ppid' => $ppid);
        $output = ctools_modal_form_wrapper('pp_del_form', $form_state);
        if (!empty($form_state['ajax_commands'])) $output = $form_state['ajax_commands'];
        print ajax_render($output);
        drupal_exit();
    }
    else return drupal_get_form('pp_del_form', $ppid);

}
/**
 * форма удаления периода роста
 */
function pp_del_form($form, &$form_state, $ppid) {
    $form_state['ppid'] = $ppid;

    $form = array(
        '#prefix' => '<div id="delete_frm">',
        '#suffix' => '</div>',
        '#attributes' => array('class' => array('custom-form'))
    );

    $form['fs1'] = array('#type' => 'fieldset', '#title' => 'Подтвердите действие');
    $form['fs1']['qwestion'] = array(
        '#markup' => 'Удалить программу защиты?',
    );

    $form['fs2'] = array('#type' => 'container', '#attributes' => array('class' => array('form-actions')));
    $form['fs2']['del_submit'] = array(
        '#type' => 'submit',
        '#value' => 'Да',
    );
    return $form;
}
/**
 * submit формы
 */
function pp_del_form_submit($form, &$form_state) {
    // удалить период из ПЗ
    node_delete($form_state['ppid']);

    // получить и вывести обновлённую ПЗ
    ctools_include('ajax');
    $form_state['ajax_commands'][] = ctools_ajax_command_reload();
}


/**
 * callback функция добавления этапа обработки
 */
