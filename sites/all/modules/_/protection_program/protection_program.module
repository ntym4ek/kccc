}
/**
 * callback функция редактирования этапа обработки
 */
function pp_stage_edit_callback($ppid, $sid, $mode = NULL) {
    if ($mode == 'ajax') {
        ctools_include('ajax'); ctools_include('modal');
        $form_state = array('ajax' => TRUE, 'title' => 'Редактировать этап обработки');
