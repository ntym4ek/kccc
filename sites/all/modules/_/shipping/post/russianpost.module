/**
 * Shipping service callback: returns a base price array for a shipping service
 * calculated for the given order.
 */
function russianpost_service_rate($shipping_service, $order) {
    $address_id = 0;
    $order_wrapper = entity_metadata_wrapper('commerce_order', $order->order_id);
    if ($order_wrapper->commerce_customer_shipping) {
        $shipping_wrapper = $order_wrapper->commerce_customer_shipping;
        $address_id = $shipping_wrapper->field_ship_address->value();
    }

    if ($address_id && $cache = cache_get('russianpost_service_rate_' . $order->order_id . '_' . $address_id)) {
        return $cache->data;
    } else {
        $set_cache = false;

        // в $order после ajax submit старые данные, загружаем заново
        $order = commerce_order_load($order->order_id);
        $order_wrapper = entity_metadata_wrapper('commerce_order', $order);

        $error = $message = '';
        $shipping_cost = $post_insurance = $post_package = 0;
        if ($address_id && $address = node_load($address_id)) {
            // проверить заполнение Обязательных полей
            $mandatory_fields = russianpost_address_book_info();
            $absent_fields = address_book_check_mandatory_fields($address, $mandatory_fields);

            if (!$absent_fields) {
                $address_wrapper = entity_metadata_wrapper('node', $address_id);
                $zipcode = trim($address_wrapper->field_ab_zipcode->value());

                $order_amount = $order_wrapper->commerce_order_total->value();
                $order_total = $order_amount['amount'] / 100;
                // почтовый сбор за страховку
                $post_insurance = $order_total * 0.04;

                // стоимость упаковочного материала
                $post_package = 150;

                $weight = commerce_physical_order_weight($order, 'kg');

                if ($weight['weight']) {
                    //$calc = russianpostcalc_api_calc("613040", $zipcode, $weight['weight'], $order_total);
                    $calc = postcalc_api_calc("613040", $zipcode, $weight['weight'], $order_total);

                    if (empty($calc['error'])) {
                        $shipping_cost = $calc['cost'];
                        $message = 'Примерный срок доставки: ' . $calc['days'] . ' дней.';
                        $set_cache = true;
                    } else {
                        $error = $calc['error'];
                        $message = $calc['message'];
                    }

                } else {
                    $error = 3;
                    $message = 'Не удалось подсчитать вес товара. Обратитесь к нашим менеджерам через форму "Задать вопрос" в правой части сайта.';
                }
            } else {
                $error = 1;
                $message = 'Заполните в выбранной записи Адресной книги следующие обязательные поля: ' . implode(', ', array_values($absent_fields));
            }


        } else {
            $error = 1;
            $message = 'Для расчёта стоимости доставки выберите запись из Адресной книги';
        }

        $calculation = array(
            'amount' => ($shipping_cost + $post_insurance + $post_package) * 100,
            'currency_code' => $order_wrapper->commerce_order_total->currency_code->value(),
            'data' => array(
                'error' => $error,
                'message' => $message,
            ),
        );

        // устанавливаем кеш на 12 часов
        if ($address_id && $set_cache) cache_set('russianpost_service_rate_' . $order->order_id . '_' . $address_id, $calculation, 'cache', time() + 43200);

        return $calculation;
    }
}


/**
 * Allows modules to alter the options array generated to select a shipping
 * service on the checkout form.
 */
function russianpost_commerce_shipping_service_rate_options_alter(&$options, $order){
    if (isset( $order->shipping_rates['russianpost_shipping_service'] )) {
        $line_item = $order->shipping_rates['russianpost_shipping_service'];
        $line_item_wrapper = entity_metadata_wrapper('commerce_line_item', $line_item);

        $amount = $line_item_wrapper->commerce_unit_price->amount->value();
        $data = $line_item_wrapper->commerce_unit_price->data->value();
        $txt_price = '';
        if (empty($data['error'])) {
            $txt_price = $amount ? commerce_currency_format($amount, $line_item_wrapper->commerce_unit_price->currency_code->value()) : t('free');
            $txt_price = '<div>Стоимость:  <span class="amount">' . $txt_price . '</span></div>';
        }

        $message = '';
        if (!empty($data['error']) && $data['error'] == 1) $message = 'уточните адрес';
        if (!empty($data['error']) && $data['error'] == 2) $message = 'расчёт не выполнен';
        if (!empty($data['error']) && $data['error'] == 3) $message = 'сервис недоступен';


        $options['russianpost_shipping_service'] = t('!shipping_service!price', array(
            '!shipping_service' => $message ? commerce_shipping_line_item_title($line_item) . '<br /><span class="error">' . $message .  '</span>' : commerce_shipping_line_item_title($line_item) . '<br />',
            '!price' => $txt_price,
        ));
    }
}

/**
 * Shipping service callback: returns the example shipping service details form.
 */
function russianpost_service_details_form($pane_form, $pane_values, $checkout_pane, $order, $shipping_service) {
    // в $order после ajax submit старые данные, загружаем заново
    $order_new = commerce_order_load($order->order_id);
    $order_wrapper = entity_metadata_wrapper('commerce_order', $order_new);

    // заполнить поля адреса и фио
    $address_id = 0;
    $address = array();
    if (!empty($order->commerce_customer_shipping)) {
        // загрузить профиль доставки и сформировать в строки
        if ($order_wrapper->commerce_customer_shipping->field_ship_address->value()) {
            $address_id = $order_wrapper->commerce_customer_shipping->field_ship_address->value();
            $address = address_book_addr_to_string($address_id);
        }
    }

    $form = array();

    $form['title'] = array(
        '#markup' => '<div class="fieldset-title">'. t('Shipping by RussianPost') .'</div>'
    );

    // если есть сообщения об ошибках - вывести
    if(isset($order->shipping_rates)) {
        $line_item_wrapper = entity_metadata_wrapper('commerce_line_item', $order->shipping_rates['russianpost_shipping_service']);
        if(isset($line_item_wrapper)) {
            $data = $line_item_wrapper->commerce_unit_price->data->value();
        }
    }

    $message = empty($data['message']) ? '' : $data['message'];
    if (!empty($data['error'])) $message = '<span class="error">' . $message . '</span>';

    $form['message'] = array(
        '#markup' => '<div class="item">' . $message . '</div>',
        '#prefix' => '<div class="fieldset">',
        '#suffix' => '</div>'
    );

    $link_adr_message = ($address_id) ? t('Address book') : t('Choose from Address Book');
    $link_adr = l($link_adr_message, 'adr-book/' . $address_id . '/russianpost/' . $order->order_id . '/nojs', array('attributes' => array('class' => array('ctools-modal-style', 'ctools-use-modal'))));

    $form['customer'] = array(
        '#markup' =>
                ($address ? ('<div class="item"><div>ФИО:</div><div id="customer">' . $address['user'] . '</div></div>') : '')
              . ($address ? ('<div class="item"><div>' . t('Address') . ':</div><div id="address">'. $address['address'] . '</div></div>') : '')
              . '<div class="info">' . $link_adr . '</div>',
        '#prefix' => '<div class="fieldset">'
            . '<div class="head">' .t('Customer information').'</div>',
        '#suffix' => '</div>',
    );


    $form['information'] = array(
        '#markup' => '<div class="info">'. 'Стоимость доставки рассчитывается автоматически на основании введенного индекса. Проверьте правильность заполнения полей ФИО и адреса получателя, чтобы Почта России могла доставить посылку без задержек.' .'</div>',
        '#prefix' => '<div class="fieldset">'
            .'  <div class="head">' .t('Description').'</div>',
        '#suffix' => '</div>'
    );

    return $form;
}

/**
 * Shipping service callback: validates the shipping service details.
 */
function russianpost_service_details_form_validate($details_form, $details_values, $shipping_service, $order, $form_parents){
    // проверить наналичие ошибок в форме
    if (strpos($details_form['message']['#markup'], 'error') !== false) {
        $error = strip_tags($details_form['message']['#markup']);
        form_set_error(implode('][', array_merge($form_parents, array('name'))), $error);
        return false;
    }
}


