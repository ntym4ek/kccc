/**
 * Implements hook_commerce_shipping_method_info().
 */
function russianpost_commerce_shipping_method_info() {
    $shipping_methods = array();

    $shipping_methods['russianpost_shipping_method'] = array(
        'title' => t('Russianpost shipping method'),
        'description' => t('Defines shipping method by russianpost with cash on delivery option.'),
    );

    return $shipping_methods;
}

/**
 * Implements hook_commerce_shipping_service_info().
 */
function russianpost_commerce_shipping_service_info() {
  $shipping_services = array();

  $shipping_services['russianpost_shipping_service'] = array(
