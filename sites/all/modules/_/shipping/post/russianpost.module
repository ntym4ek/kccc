function postcalc_api_calc($from_index, $to_index, $weight, $ob_cennost_rub) {
    $site = 'kccc.ru';
    $email = 'support@kccc.ru';
    $weight = $weight * 1000; // в граммах

    header('Content-Type: text/html; charset=utf-8');

    // Формируем запрос со всеми необходимыми переменными
    $queryString  = 'f=' .rawurlencode($from_index);
    $queryString .= '&t=' .rawurlencode($to_index);
    $queryString .= "&w=$weight&v=$ob_cennost_rub&c=RU&o=php&cs=utf-8";
    $queryString .= "&st=$site&ml=$email";

    // Формируем URL запроса.
    $request = "http://api.postcalc.ru/?$queryString";

    // Формируем опции запроса. Это необязательно, однако упрощает контроль и отладку
    $arrOptions = array('http' =>
        array( 'header'  => 'Accept-Encoding: gzip','timeout' => 5, 'user_agent' => phpversion() )
    );

    $calc = array();

    // Соединяемся с сервером
      if ($response = file_get_contents($request, false , stream_context_create($arrOptions))) {

        // Разархивируем ответ
        if ( substr($response,0,3) == "\x1f\x8b\x08" )  $response = gzinflate(substr($response,10,-8));

        // Переводим ответ в массив PHP
        $arrResponse = unserialize($response);
        
        if ($arrResponse['Status'] == 'OK') {
            if (isset($arrResponse['Отправления']['ЦеннаяПосылка'])) {

                $parcel = $arrResponse['Отправления']['ЦеннаяПосылка'];
                $calc['cost'] = $parcel['Доставка'];
                $calc['days'] = $parcel['СрокДоставки'];
                $calc['error'] = 0;

            } else {
                $calc['error'] = 2;
                $calc['message'] = 'Почтовый сервер не вернул стоимость посылки. Обратитесь в <a href="#" onclick="supportAPI.openTab(0); return false;">онлайн-поддержку</a>' ;
            }
        } else {
            $calc['error'] = 2;
            $calc['message'] = 'Почтовый сервер вернул ошибку ' . $arrResponse['Status'] . '. Обратитесь в <a href="#" onclick="supportAPI.openTab(0); return false;">онлайн-поддержку</a>' ;
        }
    } else {
        $calc['error'] = 3;
        $calc['message'] = t('No response from server. Refresh the page, please.');
    }

    return $calc;
}

function russianpostcalc_api_calc($from_index, $to_index, $weight, $ob_cennost_rub) {
    $request = array("apikey" => "225a2ea7a58b1d3fc96e256cd9f8938a",
        "method" => "calc",
        "from_index" => $from_index,
        "to_index" => $to_index,
        "weight" => $weight,
        "ob_cennost_rub" => $ob_cennost_rub
    );

    //если пароль указан, аутентификация по методу API ключ + API пароль.
    $all_to_md5 = $request;
    $all_to_md5[] = 'kccc613048';
    $hash = md5(implode("|", $all_to_md5));
    $request["hash"] = $hash;

    $curl = curl_init();
    curl_setopt($curl, CURLOPT_URL, "http://russianpostcalc.ru/api_v1.php");
    curl_setopt($curl, CURLOPT_POST, true);
    curl_setopt($curl, CURLOPT_POSTFIELDS, $request);
    curl_setopt($curl, CURLOPT_RETURNTRANSFER, true);
    $data = curl_exec($curl);

    curl_close($curl);
    if($data === false) return "10000 server error"; 

    $ret = json_decode($data, $assoc = true);

    $calc = array();

    if (isset($ret['msg']['type'])) {
        if ($ret['msg']['type'] == "done") {
            // если успешный запрос, найти стоимость обычной доставки (не 1 классом)
            foreach ($ret['calc'] as $shipping) {
                if ($shipping['type'] == 'rp_main') {
                    $calc['cost'] = $shipping['cost'];
                    $calc['days'] = $shipping['days'];
                    $calc['error'] = 0;
                }
            }
            if (empty($calc['cost'])) {
                $calc['error'] = 3;
                $calc['message'] = 'Неизвестная ошибка. Обратитесь, пожалуйста, к администратору сайта.';
            }
        } elseif ($ret['msg']['type'] == "error") {
            $calc['error'] = 2;
            $calc['message'] = $ret['msg']['text'];
        } else {
            $calc['error'] = 3;
            $calc['message'] = t('Error. Refresh the page, please.');
        }
    } else {
        $calc['error'] = 3;
        $calc['message'] = t('No response from server. Refresh the page, please.');
    }

    return $calc;
}

/**
 * функция возвращающая информацию о вызывающем модуле для модуля Address Book
 * @return array
 */
function russianpost_address_book_info() {
    return array('surname', 'name', 'name2', 'email', 'phone', 'zipcode', 'region', 'city', 'street', 'house');
}
/**
 * функция, вызываемая при ajax submit в модуле Address Book
 * вставка выбранного адреса в форму
 */
function russianpost_address_book_ajax_submit($form_state) {
    return order_address_book_ajax_submit($form_state);
}

/**
 * hook_node_presave
 * функция очищает кеш расчётов при сохранении нового или измененного адреса в модуле Address Book
 */
function russianpost_node_presave($node) {
    if ($node->type =='address') {
        if ($order_id = commerce_cart_order_id($GLOBALS['user']->uid)) {
            cache_clear_all('russianpost_service_rate_' . $order_id . '_', 'cache', TRUE);
        }
    }
}
/**
 * hook_node_delete
 * функция очищает кеш расчётов при удалении адреса в модуле Address Book
 */
function russianpost_node_delete($node) {
    if ($node->type =='address') {
        if ($order_id = commerce_cart_order_id($GLOBALS['user']->uid)) {
            cache_clear_all('russianpost_service_rate_' . $order_id . '_', 'cache', TRUE);
        }
    }
}
