/**
 * функция возвращающая информацию о вызывающем модуле для модуля Address Book
 * @return array
 */
function transport_address_book_info() {
    return array('surname', 'name', 'name2', 'email', 'phone', 'region', 'city', 'passport');
}
/**
 * функция, вызываемая при ajax submit в модуле Address Book
 * вставка выбранного адреса в форму
 */
function transport_address_book_ajax_submit($form_state) {
    return order_address_book_ajax_submit($form_state);
}

/**
 * hook_node_presave
 * функция очищает кеш расчётов при сохранении нового или измененного адреса в модуле Address Book
 */
function transport_node_presave($node) {
    if ($node->type =='address') {
        if ($order_id = commerce_cart_order_id($GLOBALS['user']->uid)) {
            cache_clear_all('transport_service_rate_' . $order_id . '_', 'cache', TRUE);
        }
    }
}
/**
 * hook_node_delete
 * функция очищает кеш расчётов при удалении адреса в модуле Address Book
 */
function transport_node_delete($node) {
    if ($node->type =='address') {
        if ($order_id = commerce_cart_order_id($GLOBALS['user']->uid)) {
            cache_clear_all('transport_service_rate_' . $order_id . '_', 'cache', TRUE);
        }
    }
}
