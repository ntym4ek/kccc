/**
 * Implements hook_init().
 */
function chibs_init()
{
    // редирект с Cart на Checkout
    if ($_GET['q'] == 'cart') drupal_goto('/checkout');

    // редирект с expo на en/expo
//    if (drupal_get_path_alias($_GET['q']) == 'expo' && $GLOBALS['language']->language == 'ru') drupal_goto('en/expo');

    // редирект с expo на en/expo
    if (drupal_get_path_alias($_GET['q']) == 'china' && $GLOBALS['language']->language == 'ru') drupal_goto('en/china');

    // запретить доступ анонимным пользователям к заданным страницам (админка - "Настройки страниц")
    if ($pages_list = variable_get('aa_list', '')) {
        foreach(explode(PHP_EOL,$pages_list) as $page_url) {
            if (!$GLOBALS['user']->uid && url($_GET['q']) == '/' . $page_url) {
                drupal_goto('toboggan/denied', array('query' => array('destination' => $page_url)));
            }
        }
    };

}

/**
 *  Implementation of hook_menu()
 */
function chibs_menu() {
    // команды для текущего модального окна (закрыть, обновить страницу)
    $items['ctools_modal/%/cmd/%'] = array(
        'page callback' => 'ctools_modal_ajax_cmd',
        'page arguments' => array(1, 3),
        'access callback' => TRUE,
        'type' => MENU_CALLBACK,
    );
    $items['promchem/firepowders/contact'] = array(
        'page callback' => 'chibs_dry_chemicals_ajax_contact',
        'access callback' => TRUE,
        'type' => MENU_CALLBACK,
    );
    $items['board/ad/%/message'] = array(
        'page callback' => 'chibs_ads_ajax_contact',
        'page arguments' => array(2),
        'access callback' => TRUE,
        'type' => MENU_CALLBACK,
    );
//    $items['run-batch'] = array(
//        'page callback' => 'chibs_run_batch',
//        'access callback' => TRUE,
//        'type' => MENU_CALLBACK,
//    );
    $items['video'] = array(
        'title' => 'Video',
        'description' => 'Video materials of OOO TD Kirovo-Chepetsk Chemical Company',
        'page callback' => 'chibs_video_router_page',
        'access arguments' => array('access content'),
        'type' => MENU_CALLBACK,
    );

    $items['admin/config/administration/manager'] = array(
        'title' => 'Настройки страниц',
        'page callback' => 'drupal_get_form',
        'page arguments' => array('chibs_settings'),
        'access arguments' => array('access manager settings'),
        'file' => 'chibs.admin.inc',
    );
    return $items;
}




/**
 * Implements hook_js_alter().
 */
function chibs_js_alter(&$js) {

    // замена версии библиотеки jquery.form с 2.69 на последнюю - 3.51
    // старая библиотека не загружала файл при использовании поля managed_file в форме с аяксифицированным сабмитом
    // или форме, размещенной во всплывающем окне
        // Define path to old jQuery Form plugin, alter to your needs.
    $old_path = drupal_get_path('module', 'jquery_update') . '/replace/misc/jquery.form.min.js';

        // The script does not get loaded on every page, so check the $js array.
    if (isset($js[$old_path])) {
        // Define path to newer jQuery Form plugin, alter to your needs.
        $new_path = drupal_get_path('module', 'chibs') . '/js/jquery.form.min.js';

        // Copy data from old javascript to new and remove old javascript.
        $js[$new_path] = $js[$old_path];
        unset($js[$old_path]);

        // Set new path as data property and alter version number.
        $js[$new_path]['data'] = $new_path;
        $js[$new_path]['version'] = '3.51.0';
    }
}

