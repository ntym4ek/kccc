/**
 * Implements hook_preprocess_menu_link().
 */
function chibs_preprocess_menu_link(&$variables)
{
    // для ссылки меню Подвал для переключения языка изменить адрес на текущую страницу
    // с учётом языка, на который идёт переход
    if ($variables['element']['#original_link']['menu_name'] == 'menu-footer' && (in_array($variables['element']['#href'], ['https://kccc.ru/en', 'https://kccc.ru']))) {
        $languages = language_list();
        $language = $variables['element']['#href'] == 'https://kccc.ru/en' ? 'en' : 'ru';
        $variables['element']['#href'] = url($_GET['q'], ['language' => $languages[$language], 'absolute' => true]);
    }
}

// не менять расширение js на js.txt для поля field_page_files, тип контента: Страница
function chibs_file_presave($file) {

    // Bypass secure file extension for .js for field_additional_js field only
    if((isset($file->source) && strpos($file->source, "field_page_files") !== FALSE) && substr($file->filename, strlen($file->filename) - 7) == ".js.txt") {

        // Define new uri and save previous
        $original_uri = $file->uri;
        $new_uri = substr($file->destination, null, -4);

        // Alter file object
        $file->filemime = 'application/javascript';
        $file->filename = substr($file->filename, null, -4);
        $file->destination = file_destination($new_uri, FILE_EXISTS_RENAME);
        $file->uri = $file->destination;

        // Move fil (to remove .txt)
        file_unmanaged_move($original_uri, $file->destination);

        // Display message that says that
        drupal_set_message(t('Security bypassed for .js for this specific field (%f).', array('%f' => $file->filename)));
    }
}



/*
 * автозаполнение полей title и alt изображений в продукции при сохранении ноды
 */
function chibs_node_submit($node, $form, &$form_state)
{
    if (strpos($node->type, 'product_') === 0 && $node->type != 'product_mix') {
        $lang = $form['body']['#language'];
        if ($lang == 'ru') {
            $site_name = t('ООО Trade House "Kirovo-Chepetsk Chemical Company"');
            $summary = $form_state['values']['body'][$lang][0]['summary'];
            $pd_wrapper = entity_metadata_wrapper('node', $node);
            if ($summary) {
                foreach ($pd_wrapper->field_product as $p_wrapper) {
                    foreach ($p_wrapper->field_p_images as $image) {
                        $image->alt = $node->title . ' - ' . strip_tags($summary) . ' - ' . $site_name;
                        $image->title = $node->title . ' - ' . strip_tags($summary) . ' - ' . $site_name;
                    }
                    $p_wrapper->save();
                }
            }
        }
    }
}

/**
 * hook_node_insert
 */
function chibs_node_insert($node)
{
  _chibs_check_and_place_node_to_front($node);
}

/**
 * hook_node_update
 */
function chibs_node_update($node)
{
  _chibs_check_and_place_node_to_front($node);
}

function _chibs_check_and_place_node_to_front($node)
{
  if (in_array($node->type, ['news', 'review'])) {
    _chibs_check_and_place_news_to_front($node);
  }
  if ($node->type == 'agenda') {
    _chibs_check_and_place_agenda_to_front($node);
  }
}

/**
 * --------------------------------------------- Авторазмещение новостей на главной -
 */
function _chibs_check_and_place_news_to_front($node_updated)
{
    // получить список новостей с галками На главную
    $query = db_select('node', 'n');
    $query->fields('n', array('nid'));
    $query->condition('n.type', ['news', 'review'], 'IN');
    $query->condition('n.promote', 1);
    $query->orderBy('n.created', 'DESC');
    $query->range(0, 2);
    $nodes = $query->execute()->fetchAll();

    // взять две последние
    // и заполнить два блока на главной (18 и 19)
    if (!empty($nodes)) {
        foreach ($nodes as $index => $node) {
          if ($node_updated->nid == $node->nid) {
            $node_wr = entity_metadata_wrapper('node', $node_updated);
          }  else {
            $node_wr = entity_metadata_wrapper('node', $node->nid);
          }

            $title = $node_wr->label();
            $url = url('node/' . $node_wr->getIdentifier());
            $image = $node_wr->field_promo_image->value();
            $uri = $image['uri'];
            $image_uri = empty($image) ? image_style_url('720_465', 'public://default_images/no_photo.png') : $uri;
//            $image_url = image_style_url('720_465', $image_uri);
            $image_url = file_create_url($image_uri);
            $section =  $node_wr->getBundle() == 'news' ? 'События' : t('Reviews');
            $block_html = '<div class="block-content no-gutters">' .
                            '<div class="block-image image-valign-center">' .
                                '<a href="' . $url . '">' .
                                    '<img src="' . $image_url . '">' .
                                '</a>' .
                            '</div>' .
                            '<div class="block-body">' .
                                '<a href="' . $url . '"><h2>' . $title . '</h2></a>' .
                                    '<p>' . $section . '</p>' .
                                '<a class="btn btn-danger" href="' . $url . '">' .
                                    t('More') . '<span class="glyphicon glyphicon-chevron-right" aria-hidden="true"></span>' .
                                '</a>' .
                            '</div>' .
                          '</div>' .
                          ($index ? '<div class="clearfix"></div>' : '');
            db_update('block_custom')->fields(array('body' => $block_html))->condition('bid', 18 + $index)->execute();
        }
    }
}

function _chibs_check_and_place_agenda_to_front($node)
{
    $voc = taxonomy_vocabulary_machine_name_load('slider_category');
    $parent = 72758;

    // найти Слайдер, относящийся к этому Материалу
    $query = db_select('taxonomy_term_data', 't');
    $query->fields('t', array('tid'));
    $query->condition('t.vid', $voc->vid);
    $query->innerJoin('field_data_field_entity_ref', 'er', 'er.entity_id = t.tid');
    $query->condition('er.field_entity_ref_target_id', $node->nid);
    $query->innerJoin('taxonomy_term_hierarchy', 'th', 'th.tid = t.tid');
    $query->condition('th.parent', $parent);
    $tid = $query->execute()->fetchField();

    if ($node->promote) {
        if (!$tid) {
            $term = (object)array(
                'vid' => $voc->vid,
                'parent' => $parent,
                'name' => 'Подробнее о мероприятии',
            );
            taxonomy_term_save($term);
            $tid = $term->tid;
        } else {
            $term = taxonomy_term_load($tid);
        }

        $term_wr = entity_metadata_wrapper('taxonomy_term', $term);

        $url = drupal_get_path_alias('node/' . $node->nid);
        $term_wr->language('ru')->name_field = 'Подробнее о мероприятии';
        $term_wr->language('en')->name_field = 'More about event';
        $term_wr->language('ru')->description_field->format = 'full_html';
        $term_wr->language('en')->description_field->format = 'full_html';
        $term_wr->language('ru')->description_field->value =    '<a class="btn btn-danger" href="/' . $url . '">' .
                                                                    '<i class="fa fa-chevron-right" aria-hidden="true"></i>' .
                                                                '</a>';
        $term_wr->language('en')->description_field->value =    '<a class="btn btn-danger" href="/en/' . $url . '">' .
                                                                    '<i class="fa fa-chevron-right" aria-hidden="true"></i>' .
                                                                '</a>';
        $term_wr->field_link = $url;
        $term_wr->field_promo_image->set($node->field_promo_image['und'][0]);
        $term_wr->field_period->value->set($node->field_period['und'][0]['value']-2*7*24*3600);
        $term_wr->field_period->value2->set($node->field_period['und'][0]['value2']);
        $term_wr->field_entity_ref = $node;
        $term_wr->save();

        // установить новый порядок
        if (isset($node->field_textfield_1['und'][0]['value']) && is_numeric($node->field_textfield_1['und'][0]['value'])) {
            $query = db_select('taxonomy_term_data', 't');
            $query->fields('t', array('tid'));
            $query->condition('t.vid', $voc->vid);
            $query->innerJoin('taxonomy_term_hierarchy', 'th', 'th.tid = t.tid');
            $query->condition('th.parent', $parent);
            $query->orderBy('t.weight');
            $tids = $query->execute()->fetchCol();

            $key = $node->field_textfield_1['und'][0]['value']-1;
            $key = $key < 0 ? 0 : $key;
            if ($tids) {
                $tids = array_diff($tids, [$tid]);
                array_splice($tids, $key, 0, $tid);

                foreach($tids as $key => $w_tid) {
                    db_update('taxonomy_term_data')->fields(array('weight' => $key))->condition('tid', $w_tid)->execute();
                }
            }
        }

    } else {
        if ($tid) taxonomy_term_delete($tid);
    }
}

