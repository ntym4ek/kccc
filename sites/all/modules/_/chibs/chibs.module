/**
 * --------------------------------- Заглушка вместо отсутствующих картинок --------------------------------------------
 * http://xandeadx.ru/blog/drupal/854
 * Preprocess function for theme_image_style().
 */
function chibs_preprocess_image_style(&$vars) {
    // для REST запросов переменная $vars['path'] вместо установки начального значения будет перезаписана
    // поэтому для REST (мобильные изображения) деф. изображения отключаем
    if (strpos($_SERVER['HTTP_HOST'],'.local') && !in_array($vars['style_name'], ['category_teaser_mob', 'mobile_teaser_product'])) {
        $vars['path'] = 'public://default_images/no_photo.png';
    }
}

/**
 * --------------------------------- Создание собственной бибилиотеки --------------------------------------------------
 * Implements hook_libraries_info().
 * https://www.drupal.org/docs/7/modules/libraries-api-7x/using-libraries-api-2x-as-a-module-developer
 * For defining external libraries.
 */
function chibs_libraries_info()
{
    // A very simple library. No changing APIs (hence, no versions), no variants.
    // Expected to be extracted into 'sites/all/libraries/ion'.
    $libraries['ionrange'] = array(
        'name' => 'Ion Range Library',
        'vendor url' => 'http://bootstraptema.ru/stuff/snippets_bootstrap/elements/ion_range_slider_bootstrap/33-1-0-2636',
        'download url' => 'http://bootstraptema.ru/stuff/snippets_bootstrap/elements/ion_range_slider_bootstrap/33-1-0-2636',
        'version arguments' => array(
            'file' => 'ion.rangeSlider.js',
            'pattern' => '@// version ([\d\.]+) B@',
            'lines' => 2,
        ),
        'files' => array(
            'js' => array('ion.rangeSlider.js'), //this can be a path to the file location like array('lib/simple.js')
            'css' => array('ion.rangeSlider.css', 'ion.rangeSlider.skin.css'),
        ),
    );
    $libraries['onscreen'] = array(
        'name' => 'OnScreen Library',
        'vendor url' => 'https://github.com/silvestreh/onScreen',
        'download url' => 'https://github.com/silvestreh/onScreen',
        'version arguments' => array(
            'file' => 'CHANGELOG.md',
            'pattern' => '@\[v([\d\.]+)\]@s',
            'lines' => 3,
        ),
        'files' => array(
            'js' => array('dist/on-screen.umd.js'), //this can be a path to the file location like array('lib/simple.js')
        ),
    );

    return $libraries;
}


/**
 * --------------------------------- Добавить view mode Front ----------------------------------------------------------
 * Implements hook_entity_info_alter().
 * http://sanchiz.net/blog/node-view-modes
 */
function chibs_entity_info_alter(&$entity_info) {
    $entity_info['node']['view modes']['front'] = array(
        'label' => t('Front', array(), array('context' => 'view mode')),
        'custom settings' => TRUE,
    );
}




/**
 * разрешаить открытие сайта в iframe для сторонних сайтов
 * http://www.unmoscerinonelweb.com/blog/drupal-7-blocks-external-frame-due-to-x-frame-options/
 */
function chibs_page_delivery_callback_alter(&$delivery_callback) {
  $domains = variable_get('ur_com_xframe_allowed', array(
      'http://77.72.142.170:8081/',
      'http://77.72.142.170/',
//      'https://youtu.be/',
//      'https://youtube.com/',
//      'https://www.youtube.com/',
  ));
  // removing frameset limitation for certain referrers
  if (in_array($_SERVER['HTTP_REFERER'], $domains)){
    //setting the variable to false in order to avoid a future setting of the header
    variable_set('x_frame_options', FALSE);
  } else {
    //default behavior
    variable_set('x_frame_options', 'SAMEORIGIN');
  }
}
