/**
 * обработчик запросов от модального окна
 * в зависимости от параметра: перейти на странице или закрыть модвльное окно
 */
function ctools_modal_ajax_cmd($js, $action) {
    if (!$js) {
        // we should never be here out of ajax context
        return MENU_NOT_FOUND;
    }

    ctools_include('modal');  ctools_include('ajax');
    ctools_add_js('ajax-responder');
    $commands = array();
    if ($action == 'goto_cart') {
        $commands[] = ctools_ajax_command_redirect('checkout');;
    }
    elseif ($action == 'dismiss') {
        $commands[] = ctools_modal_command_dismiss();
    }
    print ajax_render($commands);
    exit;
}




/**
 * ------------------------------------------ Объявления (Ads) ------------------------------------------------
 *
 * Новая модальная форма отправки сообщения по email
 */
function chibs_ads_ajax_contact($nid, $js = NULL) {
    if (!$js) {
        return drupal_get_form('chibs_ads_contact_form', $nid);
    }

    ctools_include('modal'); ctools_include('ajax');
    $form_state = array(
        'title' => t('Send message'),
        'ajax' => TRUE,
        'build_info' => array('args' => array('nid' => $nid)),
    );


    $output = ctools_modal_form_wrapper('chibs_ads_contact_form', $form_state);
    print ajax_render($output);
    exit;
}

/**
 * форма запроса контактных данных на странице описания попрошка
 */
function chibs_ads_contact_form($form, &$form_state, $nid) {
    global $user;
    $account = array();
    $form_state['adid'] = $nid;

    // СОЗДАНИЕ ФОРМЫ
    $form = array(
        '#prefix' => '<div id="contact-frm">',
        '#suffix' => '</div>',
        '#attributes' => array('class' => array('custom-form')),
    );


    // при инициализвции выводим форму
    if (empty($form_state['complete'])) {
        // задаём начальные значения
        if (empty($form_state['submitted'])) {
            $account = person_get_user_array($user);
        }

        $form['fs1'] = array('#type' => 'fieldset', '#title' => 'Ваше сообщение<i>, для автора объявления</i>');
        $form['fs1']['text'] = array(
            '#type' => 'textarea',
        );
        $form['fs2'] = array('#type' => 'fieldset', '#title' => 'Представьтесь и оставьте контакты<i>, для связи</i>', '#attributes' => array('class' => array('label-inline')));
        $form['fs2']['name'] = array(
            '#type' => 'textfield',
            '#title' => 'ФИО',
            '#default_value' => $account['full_name'],
        );
        $form['fs2']['phone'] = array(
            '#type' => 'textfield',
            '#title' => t('Phone'),
            '#default_value' => $account['phone'],
        );
        $form['fs2']['email'] = array(
            '#type' => 'textfield',
            '#title' => t('E-Mail'),
            '#default_value' => $account['email'],
        );

        $form['fs4'] = array('#type' => 'container', '#attributes' => array('class' => array('form-actions')));
        $form['fs4']['send'] = array(
            '#type' => 'submit',
            '#value' => 'Отправить',
        );
    }
    // при завершении генерируем информационное сообщение
    else {
        $form['fs1'] = array('#type' => 'fieldset', '#title' => 'Сообщение отправлено');
        $form['fs1']['info'] = array(
            '#markup' => 'Письмо с вашим сообщением отправлено автору объявления.',
        );
    }

    return $form;
}
function chibs_ads_contact_form_validate($form, &$form_state) {
    if (!valid_email_address($form_state['values']['email'])) {
        form_set_error('email', 'Введите корректный E-Mail адрес.' );
    }
    if (empty($form_state['values']['email']) && empty($form_state['values']['phone'])) form_set_error('email', 'Заполните одно из полей: ' . t('E-Mail') . ' или ' . t('Phone') . '.' );
    if (empty($form_state['values']['text'])) form_set_error('text', 'Текст сообщения обязателен' );
}
function chibs_ads_contact_form_submit($form, &$form_state) {
    // email автора
    $ad_wrapper = entity_metadata_wrapper('node', $form_state['adid']);
//    $ad = $ad_wrapper->value();
    $ad_email = $ad_wrapper->author->mail->value();
    $ad_title = $ad_wrapper->title->value();

    // отправка письма автору
    $author = '';
    $message = 'Добрый день!<br /><br />';
    $message .= 'Вам отправлено новое сообщение по объявлению "' . $ad_title . '".<br />';
    $message .= '<br />';
    $author .= empty($form_state['values']['name']) ? '' : $form_state['values']['name'] . '<br />';
    $author .= empty($form_state['values']['phone']) ? '' : 'Телефон: ' . $form_state['values']['phone'] . '<br />';
    $author .= empty($form_state['values']['email']) ? '' : 'E-Mail: ' . $form_state['values']['email'] . '<br />';


    $message .= '<b>Данные пользователя</b><br />' . $author;
    $message .= '<br />';
    $message .= '<b>Текст сообщения</b><br />';
    $message .= $form_state['values']['text'] . '<br />';

    drupal_mail('system', 'mail', $ad_email, language_default(), array(
        'context' => array(
            'subject' => 'Новое сообщение по объявлению "' . $ad_title . '"',
            'message' => $message,
        ),
    ));


    // сообщаем форме, что можно выводить сообщение об успешном сабмите и перестроить её
    $form_state['complete'] = true;
    $form_state['rebuild'] = true;
}






/**
 * Implements of hook_cron().
 * твик производительности
 * запретить удаление закэшированных страниц при автоматическом запуске крона
 */
function chibs_cron() {
    if (strpos(request_uri(), 'cron.php')) {
        if (!db_table_exists('cache_page_temp')) {
            $schema = drupal_get_schema('cache_page');
            db_rename_table('cache_page', 'cache_page_temp');
            db_create_table('cache_page', $schema);
        }
        drupal_register_shutdown_function('chibs_restore_cache_page');
    }
}
/**
 * Shutdown function for cron cleanup.
 */
function chibs_restore_cache_page() {
    db_drop_table('cache_page');
    db_rename_table('cache_page_temp', 'cache_page');
}

/**
 * ----------------------------------------------- Views ---------------------------------------------------------------
 *
 */

/**
 * Implements hook_views_data_alter().
 * твик производительности
 * добавляет во Views Fields сырые (raw) значение из БД
 */
function chibs_views_data_alter(&$data) {
    foreach ($data as $table_name => $table_info) {
        foreach ($table_info as $field_name => $field_info) {
            if (isset($field_info['field']['handler']) && $field_info['field']['handler'] == 'views_handler_field_field') {
                $field_info['field']['handler'] = 'views_handler_field';
                $field_info['title'] .= ' (raw)';
                $field_info['title short'] .= ' (raw)';
                $data[$table_name][$field_name . '_raw'] = $field_info;
            }
        }
    }
}

/**
 * Implements hook_form_views_exposed_form_alter()
 * сортировка значений в раскрытых фильтрах
 */
function chibs_form_views_exposed_form_alter(&$form, $form_state, $form_id)
{
    global $user;

    if ($form_id == 'views_exposed_form') {
        if (isset($form['culture']['#options'])) asort($form['culture']['#options']);
    }
}

/**
 * функция загружает заказ и возвращает итоговую сумму
 */
function chibs_order_total_amount($order) {
    $order_wrapper = entity_metadata_wrapper('commerce_order', $order);
    $total = NULL;
    // Loop over each line item on the order.
    foreach ($order_wrapper->commerce_line_items as $delta => $line_item_wrapper) {
        // Get the ещефд value of product line items.
        $line_item = $line_item_wrapper->value();
        if (!empty($line_item)) {
            $line_item_wrapper = entity_metadata_wrapper('commerce_line_item', $line_item);
            $total += $line_item_wrapper->commerce_total->amount->value();
        }
    }

    return $total;
}

