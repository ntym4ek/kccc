<?php

/**
 * @file
 * Imagewebp handler to change image to webp if supported.
 */

class imagewebp_views_handler_image_field extends views_handler_field_field {

  function option_definition() {
    $options = parent::option_definition();

    $options['webp_support'] = FALSE;

    return $options;
  }

  function options_form(&$form, &$form_state) {
    parent::options_form($form, $form_state); // TODO: Change the autogenerated stub

    $form['webp_support'] = array(
      '#type' => 'checkbox',
      '#title' => t('Enable Webp support'),
      '#default_value' => $this->options['webp_support'],
    );
  }

  function options_submit(&$form, &$form_state) {
    $this->options['webp_support'] = (bool)$form_state['values']['options']['webp_support'];
  }

  public function render_item($count, $item) {
    if ($this->options['webp_support']) {
      if ((isset($_SERVER['HTTP_ACCEPT']) === TRUE) && (strstr($_SERVER['HTTP_ACCEPT'], 'image/webp') !== FALSE)) {
        $path = $item['raw']['uri'];
        $filename = preg_replace('"\.(bmp|gif|png|jpg)$"', '.webp', $path);
        // Load the existing file.
        if (file_exists($filename)) {
          $item['rendered']['#item']['uri'] = $filename;
        }
        // Try to create if it does not exist.
        else {
          $file = file_load($item['raw']['fid']);
          $webp_file_create = createwebpimage($file);
          if ($webp_file_create === TRUE) {
            $item['rendered']['#item']['uri'] = $filename;
          }
        }
      }
    }
    return parent::render_item($count, $item);
  }

}
