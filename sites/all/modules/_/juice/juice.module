function juice_page_weather()
{
    drupal_add_js(drupal_get_path('module', 'juice') . '/js/juice.js');
    drupal_add_css(drupal_get_path('module', 'juice') . '/css/juice.css');

    $forecast = juice_get_weather();
    $output = theme('juice_page_weather', array('forecast' => $forecast));

    return $output;
}

