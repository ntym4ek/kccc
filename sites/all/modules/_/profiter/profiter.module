/**
 * Реализация hook_entity_info()
 */
function profiter_entity_info() {
    return array(
        'coin' => array(                                      // Системное имя сущности
            'label' => t('Coin'),                              // Человеко-понятное имя сущности
            'entity class' => 'Entity',                         // Класс сущности
            'controller class' => 'EntityAPIController',        // Контроллер сущности
            'base table' => 'coins',                          // Таблица, в которой хранится информация об альбомах
            'entity keys' => array(
                'id' => 'id',                                  // Название поля, в котором располагаются идентификаторы альбомов
            ),
            'module' => 'profiter',
        ),
        'algo' => array(                                      // Системное имя сущности
            'label' => t('Algorithm'),                              // Человеко-понятное имя сущности
            'entity class' => 'Entity',                         // Класс сущности
            'controller class' => 'EntityAPIController',        // Контроллер сущности
            'base table' => 'algorithms',                          // Таблица, в которой хранится информация об альбомах
            'entity keys' => array(
                'id' => 'id',                                  // Название поля, в котором располагаются идентификаторы альбомов
            ),
            'module' => 'profiter',
        ),
    );
}

/**
 * hook_custom_theme
 *
 * сменить тему для заданных страниц
 */
function profiter_custom_theme() {
    if ($_GET['q'] == 'profiter/main' || $_GET['q'] == 'profiter/wtm') {
        return 'gard';
    }
}

